{
  "name": "@midori/kaze",
  "version": "0.1.0",
  "description": "Fast, lightweight browser automation and E2E testing toolkit — a Playwright alternative built on Chrome DevTools Protocol",
  "keywords": ["e2e", "testing", "playwright", "browser", "automation"],
  "homepage": "https://github.com/MIDO-ruby7/kaze",
  "bugs": {
    "url": "https://github.com/MIDO-ruby7/kaze/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MIDO-ruby7/kaze"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": { "kaze": "./bin/kaze.js" },
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');const f='dist/cli/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npx tsx benchmark/perf-test.ts",
    "bench:check": "npx tsx benchmark/perf-check.ts",
    "bench:update": "npx tsx benchmark/perf-test.ts && npx tsx -e \"const r=JSON.parse(require('fs').readFileSync('benchmark/perf-results.json','utf8'));const b={};for(const[k,v]of Object.entries(r.results))b[k]=Math.ceil(v*1.5);require('fs').writeFileSync('benchmark/perf-baseline.json',JSON.stringify(b,null,2)+'\\n');\"",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
