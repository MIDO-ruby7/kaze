{
  "name": "kaze",
  "version": "0.0.1",
  "description": "Playwright-less browser automation toolkit",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": { "kaze": "./dist/cli/index.js" },
  "scripts": {
    "build": "tsup",
    "cli": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "oxlint": "^0.16.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
